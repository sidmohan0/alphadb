# Environment variables for local Polymarket discovery stack

# Required for discovery run orchestration
DATABASE_URL=postgres://postgres:postgres@localhost:5432/alphadb
REDIS_URL=redis://localhost:6379

# Optional local development settings
# DISCOVERY_SCOPE=default
# DISCOVERY_RUN_TTL_SECONDS=86400
# DISCOVERY_RUN_CACHE_TTL_SECONDS=600
# DISCOVERY_SEMAPHORE_TTL_SECONDS=60
# DISCOVERY_RUN_ALLOW_IN_MEMORY_CACHE=0
# DISCOVERY_RUN_PRUNER_ENABLED=1
# DISCOVERY_PRUNE_INTERVAL_SECONDS=300

# Postgres pool tuning
# PG_POOL_MAX=5
# PG_POOL_IDLE_TIMEOUT_MS=30000
# PG_POOL_CONNECT_TIMEOUT_MS=2000

# Optional for API defaults
# CLOB_API_URL=https://clob.polymarket.com
# CHAIN_ID=137
# WS_CONNECT_TIMEOUT_MS=12000
# WS_CHUNK_SIZE=500
# MARKET_FETCH_TIMEOUT_MS=15000
# MARKET_DISCOVERY_CONCURRENCY_LIMIT=4

# Integration test toggle
# DISCOVERY_INTEGRATION_TESTS=1

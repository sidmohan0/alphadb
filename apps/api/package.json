{
  "name": "@alphadb/api",
  "private": true,
  "version": "1.0.0",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "markets:seed-state": "ts-node --transpile-only src/markets/maintenance/seedUserState.ts",
    "polymarket:market-channels": "ts-node --transpile-only src/polymarketMarketChannels.ts",
    "discovery:ensure-schema": "ts-node --transpile-only src/polymarket/maintenance/discoverySchema.ts",
    "discovery:migrate-runs": "ts-node --transpile-only src/polymarket/maintenance/migrateDiscoveryRuns.ts",
    "test": "vitest run",
    "test:integration": "DISCOVERY_INTEGRATION_TESTS=1 vitest run test/polymarket.discovery.integration.test.ts"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.19.2",
    "ioredis": "^5.4.1",
    "pg": "^8.11.5",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.12.12",
    "@types/pg": "^8.11.0",
    "@types/supertest": "^6.0.3",
    "@types/ws": "^8.18.1",
    "supertest": "^6.3.4",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.5.4",
    "vitest": "^2.1.9"
  }
}

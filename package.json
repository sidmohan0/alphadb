{
  "name": "alphadb-platform",
  "private": true,
  "version": "1.0.0",
  "description": "AlphaDB prediction-market platform with API, web client, and ANSI TUI.",
  "scripts": {
    "dev": "concurrently -n api,web -c auto \"npm run dev --workspace @alphadb/api\" \"npm run dev --workspace @alphadb/web\"",
    "dev:tui": "npm run dev --workspace @alphadb/tui",
    "build": "npm run build --workspace @alphadb/sdk && npm run build --workspace @alphadb/api && npm run build --workspace @alphadb/web && npm run build --workspace @alphadb/tui",
    "start": "npm run start --workspace @alphadb/api",
    "test": "npm run test --workspace @alphadb/api",
    "typecheck:tui": "npm run typecheck --workspace @alphadb/tui",
    "markets:ensure-state-schema": "npm run markets:ensure-state-schema --workspace @alphadb/api",
    "markets:seed-state": "npm run markets:seed-state --workspace @alphadb/api",
    "polymarket:market-channels": "npm run polymarket:market-channels --workspace @alphadb/api",
    "polymarket:discovery-schema": "npm run discovery:ensure-schema --workspace @alphadb/api",
    "polymarket:discovery-migrate": "npm run discovery:migrate-runs --workspace @alphadb/api",
    "fly:deploy:api": "fly deploy -c deploy/fly/api.fly.toml",
    "fly:deploy:web": "fly deploy -c deploy/fly/web.fly.toml"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "dependencies": {
    "@polymarket/clob-client": "^5.3.0",
    "ethers": "^6.16.0"
  }
}
